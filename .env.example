# ============================================================================
# Baotuo-VibeForge 环境变量
# 复制本文件为 .env 并填写实际值：cp .env.example .env
# ============================================================================

# ── 必填 ────────────────────────────────────────────────────────────────

# PostgreSQL 数据库连接串
DATABASE_URL="postgresql://postgres:password@localhost:5432/vibeforge?schema=public"

# NextAuth 会话加密密钥（生成：openssl rand -base64 32）
NEXTAUTH_SECRET="请替换为随机字符串"

# 应用对外访问地址（本地开发用 http://localhost:3008）
NEXTAUTH_URL="http://localhost:3008"

# API Key 加密密钥，必须是 64 位十六进制字符（生成：openssl rand -hex 32）
ENCRYPTION_KEY="请替换为64位十六进制字符串"

# ── 可选 ────────────────────────────────────────────────────────────────

# Redis 连接串。不配置时限流会自动回退到内存实现（单实例可用，多实例需配置）
REDIS_URL="redis://localhost:6379"

# 首次 seed 时创建的管理员账号（不填则默认 admin@vibeforge.com / password123）
SEED_ADMIN_EMAIL="admin@vibeforge.com"
SEED_ADMIN_PASSWORD="password123"

# 运行环境与端口
NODE_ENV="development"
PORT="3008"

# ── Docker Compose 一键部署专用 ─────────────────────────────────────────
# 说明：用 docker-compose.prod.yml 部署时，app 通过容器网络访问数据库/Redis，
#       DATABASE_URL 和 REDIS_URL 会被 compose 内部地址覆盖，无需手动填。
#       只需保证 NEXTAUTH_SECRET / ENCRYPTION_KEY 已填，并按需修改下面两项。
#
# PostgreSQL 密码（生产务必改成强密码，compose 会用它初始化数据库）
POSTGRES_PASSWORD="password"
# PostgreSQL 数据库名
POSTGRES_DB="vibeforge"
