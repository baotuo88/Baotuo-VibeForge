# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/vibeforge"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth / Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Encryption (for API keys)
ENCRYPTION_KEY="your-encryption-key-32-chars-long"

# File Storage
STORAGE_PROVIDER="local" # local | s3 | r2 | minio
STORAGE_BUCKET="vibeforge-uploads"
STORAGE_REGION="auto"
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# AI Providers (Optional - Users can add their own)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""

# Rate Limiting
RATE_LIMIT_FREE_TIER="10" # requests per hour
RATE_LIMIT_PRO_TIER="100"
RATE_LIMIT_TEAM_TIER="1000"

# Billing (Optional - for SaaS mode)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_PRO=""
STRIPE_PRICE_ID_TEAM=""

# Feature Flags
ENABLE_TEAM_FEATURES="false"
ENABLE_BILLING="false"
ENABLE_GITHUB_INTEGRATION="false"
ENABLE_FIGMA_INTEGRATION="false"

# App Configuration
NODE_ENV="development"
PORT="3000"
API_PORT="4000"
